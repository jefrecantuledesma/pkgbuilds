# Maintainer: Samuel Biby <sbiby@gmu.edu>
pkgname='sway-solo-git'
pkgver=r2.b270b3e
pkgrel=1
pkgdesc="Kills all displays besides selected display."
arch=('x86_64')
url="https://github.com/jefrecantuledesma/sway_solo"
license=('MIT')
depends=()
makedepends=('cargo' 'git')
optdepends=()
source=("$pkgname::git+https://github.com/jefrecantuledesma/sway_solo.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/sway-solo-git"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "$srcdir/sway-solo-git"
	cargo build --release
}

package() {
	cd "$srcdir/sway-solo-git"
	install -Dm755 target/release/sway_solo "$pkgdir/usr/bin/sway-solo"
	strip "$pkgdir/usr/bin/sway-solo" 
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
